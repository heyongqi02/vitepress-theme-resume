{
  "name": "vitepress-theme-resume",
  "version": "0.0.0",
  "description": "A VitePress theme for creating resumes",
  "license": "Apache-2.0",
  "author": "Yongqi He <hi@heyongqi.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyongqi02/vitepress-theme-resume.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "repository": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && node scripts/copy-icon-fonts.mjs",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build",
    "release": "bumpp",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "simple-icons-font": "^16.23.0",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@tsdown/css": "0.22.1",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/tsconfig": "^0.9.1",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "rolldown-plugin-dts": "^0.25.2",
    "skills": "^1.5.11",
    "tailwindcss": "^4.3.0",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "unplugin-vue": "^7.2.0",
    "vite-plus": "^0.1.24",
    "vue-tsc": "~3.2.0"
  },
  "peerDependencies": {
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.38"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "pnpm@11.4.0"
}
